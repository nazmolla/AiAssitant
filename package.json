{
  "name": "nexus-agent",
  "version": "0.71.8",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/bump-version.js",
    "build": "npm run lint && npm run test && next build --webpack",
    "start": "next start",
    "lint": "eslint src/",
    "test": "jest --forceExit",
    "test:unit": "jest --selectProjects unit --forceExit",
    "test:integration": "jest --selectProjects integration --forceExit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test && npm run test:e2e",
    "test:watch": "jest --watch",
    "logs:pull": "node scripts/pull-logs.js",
    "logs:stream": "node scripts/stream-logs.js",
    "db:init": "tsx src/lib/db/init.ts",
    "deploy": "bash deploy.sh",
    "deploy:local": "npm install && npx playwright install chromium && npm run build && npm run start",
    "deploy:dev": "npm install && npx playwright install chromium && npm run dev"
  },
  "dependencies": {
