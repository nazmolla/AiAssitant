# ── Authentication ───────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ── Database ─────────────────────────────────────────────────
DATABASE_PATH=./nexus.db
# NEXUS_DB_SECRET=          # AES-256-GCM key for encrypting sensitive app_config values. Generate: openssl rand -base64 32

# ── Runtime ──────────────────────────────────────────────────
# NODE_ENV=development      # development | production | test

# ── Proactive Scheduler ─────────────────────────────────────
PROACTIVE_CRON_SCHEDULE=*/15 * * * *

# ── Access Control ───────────────────────────────────────────
# DISABLE_REGISTRATION=false  # Set to "true" to block new user sign-ups after initial admin

# ── Worker & Resource Limits ─────────────────────────────────
# WORKER_POOL_SIZE=2          # Number of worker threads for LLM calls (1–8)
# FS_ALLOWED_ROOT=            # Root boundary for filesystem tool operations (default: project root)

# ── Knowledge ────────────────────────────────────────────────
# NEXUS_DEDUPE_KNOWLEDGE_STARTUP=0  # Set to "1" to run knowledge deduplication on server startup

# ── Notes ────────────────────────────────────────────────────
# LLM providers (Azure OpenAI, OpenAI, Anthropic) are configured
# through the admin Settings > LLM Providers panel in the UI.
#
# OAuth providers (Azure AD, Google) are configured through the
# admin Settings > Authentication panel in the UI.
#
# Discord bot token and application ID are configured through the
# admin Settings > Authentication panel in the UI.
