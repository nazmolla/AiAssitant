# ── Authentication ───────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Azure AD Provider (choose one or both)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Google Provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LLM API Keys ────────────────────────────────────────────
# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (fallback)
OPENAI_API_KEY=

# ── Database ─────────────────────────────────────────────────
DATABASE_PATH=./nexus.db

# ── Proactive Scheduler ─────────────────────────────────────
PROACTIVE_CRON_SCHEDULE=*/15 * * * *
