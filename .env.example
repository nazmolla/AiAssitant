# ── Authentication ───────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ── Database ─────────────────────────────────────────────────
DATABASE_PATH=./nexus.db

# ── Proactive Scheduler ─────────────────────────────────────
PROACTIVE_CRON_SCHEDULE=*/15 * * * *

# ── Notes ────────────────────────────────────────────────────
# LLM providers (Azure OpenAI, OpenAI, Anthropic) are configured
# through the admin Settings > LLM Providers panel in the UI.
#
# OAuth providers (Azure AD, Google) are configured through the
# admin Settings > Authentication panel in the UI.
#
# Discord bot token and application ID are configured through the
# admin Settings > Authentication panel in the UI.
